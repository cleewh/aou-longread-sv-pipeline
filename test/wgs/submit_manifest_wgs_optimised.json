  "_comment": "Sample submit manifest. Replace <YOUR_BUCKET> with your S3 bucket name (typically aou-longread-sv-${ACCOUNT_ID}-${REGION}) and <YOUR_ACCOUNT> with your 12-digit AWS account ID before passing to scripts/submit-run.py. The pipeline's S3-residency gate will reject manifests that still contain placeholder strings.",
  "aws_account_id": "<YOUR_ACCOUNT>",
  "sample_id": "HG002_wgs",
  "hifi_reads_bam": "s3://<YOUR_BUCKET>/test/wgs/HG002.wgs.hifi.bam",
