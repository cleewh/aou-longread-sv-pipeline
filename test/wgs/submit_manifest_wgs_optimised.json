  "hifi_reads_aligned": true,
  "reference_fasta": "s3://<YOUR_BUCKET>/test/e2e/GRCh38.primary.fa",
  "reference_fai": "s3://<YOUR_BUCKET>/test/e2e/GRCh38.primary.fa.fai",
  "output_prefix": "s3://<YOUR_BUCKET>/test/wgs/outputs/HG002_wgs_optimised/",
  "run_hifiasm_pav": true,
  "run_sniffles2": true,
  "run_pbsv": true,
  "shard_by_chromosome": true,
  "run_storage_type": "DYNAMIC",
